# ============================================================================
# Rally Exterior Solutions — Environment Variables
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` for local development.
# In production, set these in the Vercel dashboard (Project > Settings > Environment Variables).
# NEVER commit real secrets. .env files are gitignored.
# ============================================================================

# --- Site ---------------------------------------------------------------
# Canonical, public-facing URL. Used for SEO metadata, sitemap, and schema.
NEXT_PUBLIC_SITE_URL=https://rallyexteriorsolutions.com

# ----------------------------------------------------------------------------
# LEAD DELIVERY
# The lead form posts to /api/lead. Configure ONE OR MORE of the destinations
# below. If none are set, leads are logged to the server console only (useful
# for local development). Recommended for launch: Resend + a Zapier webhook.
# ----------------------------------------------------------------------------

# --- Option A: Generic webhook (Zapier / Make / n8n / Jobber via Zapier) ---
# Any service that accepts a JSON POST. Easiest path to Jobber/HubSpot.
LEAD_WEBHOOK_URL=

# --- Option B: Resend (transactional email of each new lead) ---------------
# Get an API key at https://resend.com
RESEND_API_KEY=
LEAD_EMAIL_TO=info@rallyexteriorsolutions.com
LEAD_EMAIL_FROM=leads@rallyexteriorsolutions.com

# --- Option C: Formspree (no backend needed; set the form's POST endpoint) --
# If set, the client form posts directly here instead of /api/lead.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=

# --- Optional: simple anti-spam shared secret echoed back by the webhook ---
LEAD_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# ANALYTICS & AD TRACKING (all optional; tags only load when an ID is present)
# ----------------------------------------------------------------------------

# Google Analytics 4 — e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=

# Google Ads — conversion account, e.g. AW-XXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=
# Conversion label for a booked/submitted estimate, e.g. AbC-D_efG-h12_34-567
NEXT_PUBLIC_GOOGLE_ADS_LEAD_LABEL=

# Meta (Facebook) Pixel — numeric pixel ID
NEXT_PUBLIC_META_PIXEL_ID=

# Microsoft Clarity — heatmaps & session recordings (clarity.microsoft.com), e.g. "abcde12345"
NEXT_PUBLIC_CLARITY_ID=

# Optional: Google Site Verification token (Search Console)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# NOTE: Vercel Web Analytics + Speed Insights need no env var — just enable them
# in the Vercel dashboard (Project → Analytics / Speed Insights). They're already
# wired into the app via @vercel/analytics + @vercel/speed-insights.

# ----------------------------------------------------------------------------
# OWNER DASHBOARD ( /dashboard ) — private analytics hub
# ----------------------------------------------------------------------------
# Basic Auth credentials that gate /dashboard (required for the page to load).
DASHBOARD_USER=
DASHBOARD_PASSWORD=
# Looker Studio report embed URL (GA4 + Search Console combined). When set,
# it renders inside the dashboard. Get it from your report → Share → Embed.
NEXT_PUBLIC_LOOKER_EMBED_URL=
